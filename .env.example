# ── KODA API Keys ──────────────────────────────────────
# Copy this to .env and fill in the keys you need.
# Only the keys for your chosen provider are required.

# Anthropic (for anthropic:claude-* models)
ANTHROPIC_API_KEY=

# OpenAI (for openai:gpt-* models)
OPENAI_API_KEY=

# Jina AI (for web search & webpage reading)
JINA_API_KEY=

# Google (for google:gemini-* models)
GOOGLE_API_KEY=

# Ollama local — no key needed, just run: ollama serve
# Local models: ollama:llama3.1, ollama:codellama, ollama:mistral, etc.
# OLLAMA_HOST=http://localhost:11434
#
# Ollama Cloud — set OLLAMA_API_KEY, then EITHER use a cloud-tagged model
# (e.g. ollama:gpt-oss:120b-cloud, ollama:glm-5.1:cloud) OR set
# OLLAMA_USE_CLOUD=1 to route every ollama: model to the cloud. Cloud routing
# is opt-in, so a key alone never overrides a local `ollama serve`.
# OLLAMA_API_KEY=
# OLLAMA_USE_CLOUD=0
# OLLAMA_CLOUD_HOST=https://ollama.com

# LM Studio — local at http://localhost:1234/v1 by default.
# If local is unreachable, KODA will try this URL as a fallback:
# LMSTUDIO_CLOUD_BASE_URL=

# MiniMax — internal OpenAI-compatible endpoint used as the default by
# coding_agent/agent.py. The model name is a constant in code; only the
# connection settings live here.
MINIMAX_API_KEY=EMPTY

# ── Observability ──────────────────────────────────────
# Langfuse — traces every LLM call + tool invocation in the coding agent.
# Optional: leave blank to disable. The SDK degrades to a silent no-op.
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_BASE_URL=https://cloud.langfuse.com   # or your self-hosted URL
# Optional grouping for the Langfuse Sessions view:
# KODA_SESSION_ID=                                # default: random uuid4 per run

# ── Onboarding ─────────────────────────────────────────
# Set to 1 once first-run setup is complete so KODA never auto-shows the
# onboarding screen again (written automatically when you Save in /setup).
# Run /setup anytime to change keys or switch client (Ollama local vs cloud).
# KODA_ONBOARDED=1
